{
  "name": "archiveos-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "serve:dev": "tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "batch:nightly-review": "tsx src/batches/runBatch.ts nightly-review",
    "batch:daily-report": "tsx src/batches/runBatch.ts daily-report",
    "batch:supabase-keepalive": "tsx src/batches/runBatch.ts supabase-keepalive",
    "architect:review-demo": "tsx src/architect/runArchitectDemo.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.86.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.25",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
