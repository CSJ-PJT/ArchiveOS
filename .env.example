VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_BACKEND_URL=http://localhost:4000
VITE_REMOTE_FRONTEND_URL=
VITE_REMOTE_BACKEND_URL=
VITE_COMMIT_SHA=
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ARCHIVE_TOKEN_MARKET_TO_OS=
ARCHIVE_TOKEN_NEXUS_TO_OS=
ARCHIVE_TOKEN_LOGISTICS_TO_OS=
ARCHIVE_TOKEN_LEDGER_TO_OS=
ARCHIVE_TOKEN_OS_TO_LEDGER=
ARCHIVE_TOKEN_AUTHENTICATED_READ=
ARCHIVE_TOKEN_ADMIN_OPERATOR=
# Archive-World Digital Twin adapter. The manifest is mounted read-only into archiveos-ai.
ARCHIVE_WORLD_ADAPTER_MODE=mock
HOST_ARCHIVE_WORLD_ROOT=../Archive-World
ARCHIVE_WORLD_EVENT_LIMIT=100
OBSIDIAN_VAULT_PATH=
HOST_OBSIDIAN_VAULT_PATH=./docs
OBSIDIAN_CHUNK_SIZE=1200
OBSIDIAN_CHUNK_OVERLAP=160
RAG_MAX_REFERENCES=5
DB_HOST=localhost
DB_HOST_PORT=5432
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
ARCHIVEOS_AI_BASE_URL=http://localhost:4100
ARCHIVEOS_PUBLIC_URL=
ARCHIVEOS_BACKEND_PUBLIC_URL=
ARCHIVEOS_SCHEDULER_ENABLED=false
# Development default preserves the existing application behavior. The RC overlay
# resolves this to false unless an operator explicitly sets it.
ARCHIVE_LIVE_FLOW_COLLECTOR_ENABLED=true
ARCHIVE_RAG_SEARCH_RATE_LIMIT_PER_MINUTE=60
ARCHIVE_RAG_ASK_RATE_LIMIT_PER_MINUTE=12
CORS_ALLOWED_ORIGINS=http://localhost:5173
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_CHANNEL=archiveos-alerts
# ArchiveOS admin session (local secret; never commit the real value)
ARCHIVEOS_ADMIN_PASSWORD=
ARCHIVEOS_INTEGRATION_TOKEN=
ARCHIVEOS_SESSION_TIMEOUT_MINUTES=30
ARCHIVEOS_LOGIN_MAX_ATTEMPTS=5
ARCHIVEOS_LOGIN_LOCKOUT_MINUTES=15
ARCHIVEOS_SECURE_COOKIE=false

# Archive-Ledger external approval callback integration.
# Store real values only in local .env or deployment secret manager.
ARCHIVE_LEDGER_BASE_URL=
ARCHIVE_LEDGER_ENABLED=false

# Archive Platform Ecosystem integration.
# In Docker Compose, use host.docker.internal when Nexus/Logitics/Ledger run on the host.
ARCHIVE_ECOSYSTEM_ENABLED=true
ARCHIVE_ECOSYSTEM_REFRESH_TIMEOUT_MS=3000
ARCHIVE_ECOSYSTEM_SERVICES_MARKET_ENABLED=true
ARCHIVE_ECOSYSTEM_SERVICES_MARKET_BASE_URL=http://localhost:8094
ARCHIVE_ECOSYSTEM_SERVICES_NEXUS_ENABLED=true
ARCHIVE_ECOSYSTEM_SERVICES_NEXUS_BASE_URL=http://localhost:8080
ARCHIVE_ECOSYSTEM_SERVICES_LOGITICS_ENABLED=true
ARCHIVE_ECOSYSTEM_SERVICES_LOGITICS_BASE_URL=http://localhost:8092
ARCHIVE_ECOSYSTEM_SERVICES_LEDGER_ENABLED=true
ARCHIVE_ECOSYSTEM_SERVICES_LEDGER_BASE_URL=http://localhost:18080
ARCHIVE_INTEGRATION_SAFE_MODE=true
ARCHIVE_INTEGRATION_ALLOW_EXTERNAL_WRITE=false
ARCHIVE_INTEGRATION_CALLBACK_ENABLED=true
ARCHIVE_INTEGRATION_CALLBACK_MAX_RETRY_COUNT=5
ARCHIVE_INTEGRATION_CALLBACK_RETRY_DELAY_SECONDS=30
